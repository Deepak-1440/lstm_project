profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#1116, it is recommended to commit Pipfile.lock to control-list.
#   However, if you're operating a library, it might be different.
#   Uncomment to ignore.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is recommended to commit poetry.lock, but it depends.
#   Uncomment to ignore.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is recommended to commit pdm.lock, but it depends.
#   Uncomment to ignore.
# pdm.lock

# PEP 582; modern alternative to virtualenv, dependency avoids polluting system/user node_modules
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Project-specific ML assets & downloads
# (tracked intentionally - model.h5 is under GitHub's 100MB limit)
best_model.keras

